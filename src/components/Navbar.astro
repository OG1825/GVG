---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Bounties', href: '/bounties' },
  { label: 'How it Works', href: '/how-it-works' },
  { label: 'Events', href: '/events' },
  { label: 'Partners', href: '/partners' },
  { label: 'Join', href: '/join' }
];

const isActive = (href: string) => {
  if (href === '/' && currentPath === '/') return true;
  if (href !== '/' && currentPath.startsWith(href)) return true;
  return false;
};
---

<nav class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
  <div class="container-custom py-4">
    <div class="flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 font-bold text-2xl text-primary hover:text-accent">
        <span>🚀</span>
        <span>GVG</span>
      </a>

      <div class="hidden md:flex gap-8">
        {navItems.map(item => (
          <a
            href={item.href}
            class={`font-semibold text-sm transition-colors ${
              isActive(item.href)
                ? 'text-accent border-b-2 border-accent pb-1'
                : 'text-gray-700 hover:text-primary'
            }`}
          >
            {item.label}
          </a>
        ))}
      </div>

      <div class="hidden md:block">
        <a href="/join" class="btn-primary text-sm">
          Join Guild
        </a>
      </div>

      <details class="md:hidden group">
        <summary class="cursor-pointer font-bold text-xl text-primary hover:text-accent">
          ☰
        </summary>
        <div class="absolute top-full right-0 mt-2 bg-white rounded-lg border border-gray-200 shadow-lg p-4 w-48">
          {navItems.map(item => (
            <a
              href={item.href}
              class={`block py-2 px-3 rounded font-semibold transition-colors ${
                isActive(item.href)
                  ? 'bg-blue-50 text-accent'
                  : 'text-gray-700 hover:bg-gray-50'
              }`}
            >
              {item.label}
            </a>
          ))}
          <a href="/join" class="block w-full mt-3 btn-primary text-center text-sm">
            Join Guild
          </a>
        </div>
      </details>
    </div>
  </div>
</nav>
