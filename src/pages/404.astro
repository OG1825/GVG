---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
---

<Layout title="Page Not Found">
  <section class="min-h-screen bg-gradient-to-br from-primary via-primary to-secondary text-white flex items-center">
    <div class="container-custom text-center">
      <h1 class="text-9xl md:text-[10rem] font-bold mb-4 opacity-20">404</h1>
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Page Not Found</h2>
      <p class="text-xl text-blue-100 mb-12 max-w-2xl mx-auto">
        Looks like this page doesn't exist or has been moved. Let's get you back on track.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/" variant="secondary" size="lg">
          ← Back to Home
        </Button>
        <Button href="/bounties" variant="primary" size="lg">
          Browse Bounties
        </Button>
      </div>

      <p class="text-blue-200 mt-12 text-sm">
        If you think this is an error, <a href="mailto:help@gvg.example.com" class="underline hover:no-underline">let us know</a>.
      </p>
    </div>
  </section>
</Layout>
